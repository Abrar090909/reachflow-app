PORT=3001
APP_SECRET=your-random-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Base URL for tracking pixel (no trailing slash)
# Local dev:  http://localhost:3001
# Production: https://your-backend.onrender.com
APP_BASE_URL=http://localhost:3001

# Gmail OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/accounts/gmail/callback

# Optional Brevo API key (bypasses SMTP, for Zoho accounts)
BREVO_API_KEY=

# Optional: your own email for test sends
TEST_EMAIL=

# Optional: Turso cloud SQLite (leave blank to use local file)
TURSO_URL=
TURSO_AUTH_TOKEN=
