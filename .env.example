PORT=3001
APP_SECRET=your-random-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Base URL for open/click tracking pixel (no trailing slash)
# Local:      http://localhost:3001
# Production: https://your-render-backend.onrender.com
APP_BASE_URL=http://localhost:3001

# Gmail OAuth — get from Google Cloud Console
# https://console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/accounts/gmail/callback

# Optional: email address to receive test sends
TEST_EMAIL=

# Optional: Turso cloud SQLite (leave blank to use local file DB)
TURSO_URL=
TURSO_AUTH_TOKEN=
